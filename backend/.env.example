PORT=4000
# DATA_PATH=./data.json
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000
SESSION_SECRET=replace-with-random-string
APP_SECRET=replace-with-long-random-secret
ADMIN_USER=tzadmin
ADMIN_PASSWORD=8mayjkjk
# COOKIE_SECURE=1

# --- Telegram (опционально). Токен и секрет только в локальном .env, не коммитить. ---
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_ADMIN_IDS=404740026
#
# Вариант А — прод: вебхук (нужен публичный HTTPS). TELEGRAM_WEBHOOK_SECRET + URL в @BotFather:
# TELEGRAM_WEBHOOK_SECRET=случайная-длинная-строка
# /setwebhook → https://ваш-домен/api/telegram/webhook/<TELEGRAM_WEBHOOK_SECRET>
#
# Вариант Б — тест без домена: long polling (только токен, секрет не обязателен):
# TELEGRAM_POLLING=1
# Ссылка на оплату (Т‑Банк и т.п.) для бота — по умолчанию встроенный URL, можно переопределить:
# TELEGRAM_PAYMENT_URL=https://www.tbank.ru/cf/81hWUzyhiQB
# Кнопки «Подтвердить» / «Платёж не поступил» у чека — только для id из TELEGRAM_ADMIN_IDS; если список пуст, используется 404740026.
# Период авто-уведомлений о трафике (мс), минимум 60000. По умолчанию 10 минут.
# TELEGRAM_TRAFFIC_NOTIFY_INTERVAL_MS=600000
